'==================================================================
' PARALLEL SEARCH DISPATCH (Bucket 3, v2.5.2 with cross-entity batching + CAPTCHA retry)
'==================================================================

' Runs a flat collection of search tasks.
' Each task is Array(query, savePath, pageNum, description, entityLabel).
' In headless mode: up to MAX_PARALLEL concurrent msedge.exe across
' ALL tasks (cross-entity); workers never sit idle between entities.
' Small PDFs (possible CAPTCHAs) get one automatic retry after a 15s
' cooldown, using the same worker pool.
' In interactive mode: serial (one at a time).
' Returns the count of tasks that produced a valid PDF on disk.
Private Function RunSearchBatch(tasks As Collection, wsh As Object) As Long
    If tasks Is Nothing Then Exit Function
    If tasks.Count = 0 Then Exit Function

    If USE_HEADLESS Then
        RunSearchBatch = RunSearchBatchParallel(tasks, wsh)
    Else
        RunSearchBatch = RunSearchBatchSerial(tasks, wsh)
    End If
End Function

Private Function RunSearchBatchParallel(tasks As Collection, wsh As Object) As Long
    On Error Resume Next

    Dim n As Long: n = tasks.Count
    If n = 0 Then Exit Function

    Dim batchStartT As Single: batchStartT = Timer
    LogStep "BATCH ALL start, n=" & n & ", maxParallel=" & MAX_PARALLEL

    ' ---------- Pass 1: initial dispatch ----------
    Dim initialSizes() As Long
    DispatchTaskPass tasks, wsh, "initial", initialSizes

    ' Build retry collection from tasks that produced a suspiciously
    ' small PDF (valid-ish size, but probably a CAPTCHA page).
    Dim retryList As Collection
    Set retryList = New Collection

    Dim i As Long, a As Variant
    For i = 1 To n
        If i <= UBound(initialSizes) Then
            If initialSizes(i) > MIN_PDF_SIZE_BYTES And _
               initialSizes(i) < CAPTCHA_SIZE_HINT Then
                retryList.Add tasks(i)
            End If
        End If
    Next i

    ' ---------- Pass 2: CAPTCHA retry after cooldown ----------
    If retryList.Count > 0 And Not bAbort Then
        LogStep "CAPTCHA COOLDOWN: " & retryList.Count & _
                " tasks flagged - waiting 15s before retry"
        Application.StatusBar = "OSINT: CAPTCHA cooldown (" & retryList.Count & _
                                " tasks) - waiting 15s before retry..."
        SmartWait 15, False  ' ESC still works during cooldown

        If Not bAbort Then
            Dim retrySizes() As Long
            DispatchTaskPass retryList, wsh, "retry", retrySizes
        End If
    End If

    ' ---------- Final count: actual valid PDFs on disk ----------
    Dim finalSuccess As Long
    For i = 1 To n
        a = tasks(i)
        On Error Resume Next
        If FileLen(CStr(a(1))) > MIN_PDF_SIZE_BYTES Then
            finalSuccess = finalSuccess + 1
        End If
        On Error GoTo 0
    Next i

    LogStep "BATCH ALL end, success=" & finalSuccess & "/" & n & _
            " wall=" & CLng(Timer - batchStartT) & "s retries=" & retryList.Count

    RunSearchBatchParallel = finalSuccess
End Function

' Single-pass parallel dispatch over a tasks collection.
' Fills finalSizes(1..n) with the on-disk size after each task completes
' (0 if failed/timed out). Caller uses this to decide whether to retry.
Private Sub DispatchTaskPass(tasks As Collection, _
                             wsh As Object, _
                             ByVal passLabel As String, _
                             ByRef finalSizes() As Long)
    On Error GoTo Fail

    Dim n As Long: n = tasks.Count
    If n = 0 Then
        ReDim finalSizes(1 To 1)  ' avoid uninitialised-array issues in caller
        Exit Sub
    End If

    Dim qry() As String, pth() As String, pg() As Long
    Dim dsc() As String, lbl() As String
    Dim st() As Long         ' 0=pending, 1=running, 2=done, 3=failed
    Dim launchT() As Date
    Dim wk() As Long
    ReDim qry(1 To n), pth(1 To n), pg(1 To n), dsc(1 To n), lbl(1 To n)
    ReDim st(1 To n), launchT(1 To n), wk(1 To n)
    ReDim finalSizes(1 To n)

    Dim i As Long, a As Variant
    For i = 1 To n
        a = tasks(i)
        qry(i) = CStr(a(0))
        pth(i) = CStr(a(1))
        pg(i) = CLng(a(2))
        dsc(i) = CStr(a(3))
        If UBound(a) >= 4 Then lbl(i) = CStr(a(4)) Else lbl(i) = ""
    Next i

    Dim busy() As Boolean
    ReDim busy(0 To MAX_PARALLEL - 1)

    Dim doneCount As Long, runningCount As Long, successCount As Long
    Dim w As Long, pendingFound As Boolean
    Dim cmd As String
    Dim sz As Long
    Dim passStartT As Single: passStartT = Timer
    Dim taskDurSec As Long
    Dim currLabel As String

    LogStep "PASS [" & passLabel & "] start, n=" & n

    Do
        ' Fill any free worker slots with pending tasks
        For w = 0 To MAX_PARALLEL - 1
            If bAbort Then Exit For
            If Not busy(w) Then
                pendingFound = False
                For i = 1 To n
                    If bAbort Then Exit For
                    If st(i) = 0 Then
                        On Error Resume Next
                        If Dir(pth(i)) <> "" Then Kill pth(i)
                        On Error GoTo Fail

                        cmd = BuildHeadlessEdgeCmd(qry(i), pth(i), pg(i), w)
                        wsh.Run cmd, 0, False

                        st(i) = 1
                        launchT(i) = Now
                        wk(i) = w
                        busy(w) = True
                        runningCount = runningCount + 1
                        pendingFound = True

                        LogStep "  TASK launch [" & i & "/" & n & "] w" & w & _
                                " running=" & runningCount & _
                                " [" & lbl(i) & "] " & dsc(i)

                        SmartWait T(LAUNCH_STAGGER_SEC), True
                        Exit For
                    End If
                Next i
                If Not pendingFound Then Exit For
            End If
        Next w

        ' Poll for completions or timeouts
        For i = 1 To n
            If st(i) = 1 Then
                sz = 0
                If Dir(pth(i)) <> "" Then
                    On Error Resume Next
                    sz = FileLen(pth(i))
                    On Error GoTo Fail
                End If

                If sz > MIN_PDF_SIZE_BYTES Then
                    st(i) = 2
                    finalSizes(i) = sz
                    successCount = successCount + 1
                    doneCount = doneCount + 1
                    runningCount = runningCount - 1
                    busy(wk(i)) = False
                    taskDurSec = DateDiff("s", launchT(i), Now)
                    currLabel = lbl(i)

                    LogStep "  TASK done  [" & i & "/" & n & "] w" & wk(i) & _
                            " dur=" & taskDurSec & "s size=" & sz & "B running=" & runningCount

                    If sz < CAPTCHA_SIZE_HINT Then
                        LogStep "  TASK warn  [" & i & "/" & n & "] small PDF " & sz & _
                                "B (possible CAPTCHA) - [" & lbl(i) & "] " & dsc(i)
                    End If

                ElseIf DateDiff("s", launchT(i), Now) > TASK_TIMEOUT_SEC Then
                    st(i) = 3
                    finalSizes(i) = 0
                    doneCount = doneCount + 1
                    runningCount = runningCount - 1
                    busy(wk(i)) = False
                    LogStep "  TASK TIMEOUT [" & i & "/" & n & "] w" & wk(i) & _
                            " after " & TASK_TIMEOUT_SEC & "s - [" & lbl(i) & "] " & dsc(i)
                End If
            End If
        Next i

        ' Status bar: show pass + most-recent entity + progress
        If currLabel <> "" Then
            Application.StatusBar = "OSINT [" & passLabel & "]: " & currLabel & " - " & _
                doneCount & "/" & n & " saved, " & runningCount & " running"
        Else
            Application.StatusBar = "OSINT [" & passLabel & "]: " & _
                doneCount & "/" & n & " saved, " & runningCount & " running"
        End If

        If bAbort Then Exit Do
        SmartWait T(POLL_INTERVAL_SEC)
    Loop While doneCount < n

    LogStep "PASS [" & passLabel & "] end, success=" & successCount & "/" & n & _
            " wall=" & CLng(Timer - passStartT) & "s"
    Exit Sub
Fail:
    LogStep "PASS [" & passLabel & "] FAIL err=" & Err.Number & " desc=" & Err.Description
End Sub

Private Function RunSearchBatchSerial(tasks As Collection, wsh As Object) As Long
    Dim n As Long: n = tasks.Count
    Dim i As Long, successCount As Long
    Dim a As Variant
    Dim currLabel As String, currDesc As String

    For i = 1 To n
        a = tasks(i)
        currDesc = CStr(a(3))
        If UBound(a) >= 4 Then currLabel = CStr(a(4)) Else currLabel = "Search"

        SetSearchStatus currLabel, currDesc & " (" & i & "/" & n & ")"
        If PrintSearchToPDF(CStr(a(0)), CStr(a(1)), wsh, CLng(a(2))) Then
            successCount = successCount + 1
        End If
        If bAbort Then Exit For
    Next i

    RunSearchBatchSerial = successCount
End Function

'==================================================================
' SEARCH ENGINE
'==================================================================

Function PrintSearchToPDF(Query As String, savePath As String, wsh As Object, _
                          Optional PageNum As Long = 1) As Boolean
    If USE_HEADLESS Then
        PrintSearchToPDF = PrintSearchToPDF_Headless(Query, savePath, PageNum, wsh, 0)
    Else
        PrintSearchToPDF = PrintSearchToPDF_Interactive(Query, savePath, wsh, PageNum)
    End If
End Function

'------------------------------------------------------------------
' HEADLESS MODE - single-task (kept for compatibility + interactive fallback).
' Parallel dispatch calls BuildHeadlessEdgeCmd directly with per-worker idx.
'------------------------------------------------------------------
Private Function PrintSearchToPDF_Headless(Query As String, _
                                           savePath As String, _
                                           ByVal PageNum As Long, _
                                           wsh As Object, _
                                           ByVal workerIdx As Long) As Boolean
    On Error GoTo FuncFail

    Dim cmd As String

    On Error Resume Next
    If Dir(savePath) <> "" Then Kill savePath
    On Error GoTo FuncFail

    cmd = BuildHeadlessEdgeCmd(Query, savePath, PageNum, workerIdx)

    ' Synchronous when called from the single-task path.
    ' Parallel dispatch calls BuildHeadlessEdgeCmd directly and uses Run False.
    wsh.Run cmd, 0, True

    Dim resultSize As Long
    If Dir(savePath) <> "" Then resultSize = FileLen(savePath)

    If resultSize < CAPTCHA_SIZE_HINT And resultSize > MIN_PDF_SIZE_BYTES Then
        Debug.Print "WARN: small headless PDF (" & resultSize & " B) - possible CAPTCHA: " & savePath
    End If

    PrintSearchToPDF_Headless = (resultSize > MIN_PDF_SIZE_BYTES)
    Exit Function
FuncFail:
    PrintSearchToPDF_Headless = False
End Function

'------------------------------------------------------------------
' Build headless Edge command line.
' workerIdx selects --user-data-dir, so 3 parallel processes get
' 3 independent profile locks instead of fighting for one.
'------------------------------------------------------------------
Private Function BuildHeadlessEdgeCmd(ByVal Query As String, _
                                      ByVal savePath As String, _
                                      ByVal PageNum As Long, _
                                      ByVal workerIdx As Long) As String
    Dim baseURL As String, edgeExe As String, profilePath As String
    Dim ua As String, s As String

    baseURL = "https://www.google.com/search?q=" & URLEncode(Query) & "&num=100&hl=en"
    If PageNum > 1 Then baseURL = baseURL & "&start=" & ((PageNum - 1) * 10)

    edgeExe = GetEdgePath
    profilePath = GetWorkerProfilePath(workerIdx)

    ua = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 " & _
         "(KHTML, like Gecko) Chrome/131.0.0.0 Safari/537.36 Edg/131.0.0.0"

    ' v2.5.1: stripped back to match v2.4.5 + only safe micro-optimizations.
    ' Removed (were hurting perf or had zero benefit):
    '   --disable-features=...,VizDisplayCompositor,...  (forces slow
    '     legacy rasterizer - primary perf regression vs v2.4.5)
    '   --disable-breakpad, --disable-translate,
    '   --disable-ipc-flooding-protection, --disable-hang-monitor
    '     (marginal or negative impact)
    ' Kept: the v2.4.5 baseline + audio/scrollbars/pings/sync/
    ' component-update/default-apps/metrics/phishing (all safe).
    ' --no-pdf-header-footer OMITTED on purpose (keep default headers).
    s = """" & edgeExe & """"
